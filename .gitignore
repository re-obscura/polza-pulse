# Зависимости
node_modules/

# Результаты сборки (esbuild)
dist-main/
dist-preload/
dist-renderer/

# Результаты electron-builder (установщики, latest.yml и т.д.)
release/
dist/
*.exe
*.blockmap

# Папка с релизными артефактами для автообновления (в Git, ветка dev).
# Исключаем из общих правил *.exe и *.blockmap.
!releases/
!releases/*.exe
!releases/*.blockmap
!releases/latest.yml

# Логи
*.log

# Системные файлы
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Env-файлы (токены, ключи)
.env
.env.local
.env.*.local

# ZCode
.zcode/

# Инструкция по сборке и релизу (только локально)
RELEASE.md

# Система macOS
*.dmg

# Система Linux
*.AppImage
*.snap
*.deb
*.rpm
